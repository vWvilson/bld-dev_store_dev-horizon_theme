{%- if section.blocks.size > 0 -%}
<div class="product-tabs accordion">
  {%- for block in section.blocks -%}
  {%- case block.type -%}

  {%- when 'description' -%}
  <div class="accordion-item" {{ block.shopify_attributes }}>
    <button class="accordion-toggle nav-link{% if forloop.first %} active{% endif %}" aria-expanded="{% if forloop.first %}true{% else %}false{% endif %}" aria-controls="product_tabs_description">
      {{ block.settings.title }}
      <span class="accordion-icon"></span>
    </button>
    <div class="tab-content{% if forloop.first %} show active{% endif %}" id="product_tabs_description">
      <div class="product-tabs-content-inner clearfix">
        {%- assign description = product.description -%}
        {%- if description contains '[countdown]' -%}
        {%- assign description = description | split:'[/countdown]' | last -%}
        {%- endif -%}
        {%- if product.description contains '[shortdesc]' -%}
        {%- assign description = description | split:'[/shortdesc]' | last -%}
        {%- endif -%}
        {%- if product.description contains '[additional]' -%}
        {%- assign description = description | split:'[/additional]' | last -%}
        {%- endif -%}
        {{ description }}
      </div>
    </div>
  </div>

  {%- when 'review' -%}
  <div class="accordion-item reviews_tab" {{ block.shopify_attributes }}>
    <button class="accordion-toggle nav-link{% if forloop.first %} active{% endif %}" aria-expanded="{% if forloop.first %}true{% else %}false{% endif %}" aria-controls="product_tabs_tabreviews">
      {{ block.settings.title }}
      {%- if block.settings.use_count_reviews -%}
      <script type="text/javascript">
        $(function(){
          var revcount = $('meta[itemprop=reviewCount]').length > 0
            ? '(' + $('meta[itemprop=reviewCount]').attr('content') + ')'
            : '(0)';
          $('.reviews_tab .accordion-toggle').append(revcount);
        });
      </script>
      {%- endif -%}
      <span class="accordion-icon"></span>
    </button>
    <div class="tab-content{% if forloop.first %} show active{% endif %}" id="product_tabs_tabreviews">
      <div class="product-tabs-content-inner clearfix">
        <div id="shopify-product-reviews" data-id="{{ product.id }}">{{ product.metafields.spr.reviews }}</div>
      </div>
    </div>
  </div>

  {%- when 'additional' -%}
  {%- if product.description contains '[additional]' -%}
  <div class="accordion-item" {{ block.shopify_attributes }}>
    <button class="accordion-toggle nav-link{% if forloop.first %} active{% endif %}" aria-expanded="{% if forloop.first %}true{% else %}false{% endif %}" aria-controls="product_tabs_additional">
      {{ block.settings.title }}
      <span class="accordion-icon"></span>
    </button>
    <div class="tab-content{% if forloop.first %} show active{% endif %}" id="product_tabs_additional">
      <div class="product-tabs-content-inner clearfix">
        {%- assign get = product.description | split:'[/additional]' | first -%}
        {%- assign additional = get | split:'[additional]' | last -%}
        {{ additional }}
      </div>
    </div>
  </div>
  {%- endif -%}

  {%- when 'size_chart' -%}
  {%- if block.settings.size_chart_image != blank or block.settings.code != '' -%}
  <div class="accordion-item" {{ block.shopify_attributes }}>
    <button class="accordion-toggle nav-link{% if forloop.first %} active{% endif %}" aria-expanded="{% if forloop.first %}true{% else %}false{% endif %}" aria-controls="product_tabs_size_chart">
      {{ block.settings.title }}
      <span class="accordion-icon"></span>
    </button>
    <div class="tab-content{% if forloop.first %} show active{% endif %}" id="product_tabs_size_chart">
      <div class="product-tabs-content-inner clearfix">
        {%- if block.settings.size_chart_image != blank -%}
          <img data-src="{{ block.settings.size_chart_image | img_url: 'master' }}" class="img-responsive" />
        {%- else -%}
          {{ block.settings.code }}
        {%- endif -%}
      </div>
    </div>
  </div>
  {%- endif -%}

  {%- when 'html' -%}
  {%- if block.settings.code != '' -%}
  <div class="accordion-item" {{ block.shopify_attributes }}>
    <button class="accordion-toggle nav-link{% if forloop.first %} active{% endif %}" aria-expanded="{% if forloop.first %}true{% else %}false{% endif %}" aria-controls="tab{{ block.id }}">
      {{ block.settings.title }}
      <span class="accordion-icon"></span>
    </button>
    <div class="tab-content{% if forloop.first %} show active{% endif %}" id="tab{{ block.id }}">
      <div class="product-tabs-content-inner clearfix">
        {{ block.settings.code }}
      </div>
    </div>
  </div>
  {%- endif -%}

  {%- endcase -%}
  {%- endfor -%}
</div>
{%- endif -%}

{% schema %}
{
  "name": "t:sections.product-page-tab.name",
  "settings": [
    {
      "type": "paragraph",
      "content": "t:sections.product-page-tab.settings.paragraph.content"
    }
  ],
  "blocks": [
    {
      "type": "description",
      "name": "t:sections.product-page-tab.blocks.description.name",
      "limit": 1,
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "t:sections.product-page-tab.blocks.general.settings.title.label",
          "default": "Description"
        }
      ]
    },
    {
      "type": "review",
      "name": "t:sections.product-page-tab.blocks.review.name",
      "limit": 1,
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "t:sections.product-page-tab.blocks.general.settings.title.label",
          "default": "Reviews"
        },
        {
          "type": "checkbox",
          "id": "use_count_reviews",
          "label": "t:sections.product-page-tab.blocks.review.settings.use_count_reviews.label",
          "default": false
        }
      ]
    },
    {
      "type": "additional",
      "name": "t:sections.product-page-tab.blocks.additional.name",
      "limit": 1,
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "t:sections.product-page-tab.blocks.general.settings.title.label",
          "default": "Additional Information"
        }
      ]
    },
    {
      "type": "size_chart",
      "name": "t:sections.product-page-tab.blocks.size_chart.name",
      "limit": 1,
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "t:sections.product-page-tab.blocks.general.settings.title.label",
          "default": "Size Chart"
        },
        {
          "type": "image_picker",
          "id": "size_chart_image",
          "label": "t:sections.product-page-tab.blocks.size_chart.settings.size_chart_image.label"
        },
        {
          "type": "html",
          "id": "code",
          "label": "t:sections.product-page-tab.blocks.general.settings.code.label",
          "default": "<div class=\"row\"><div class=\"col-lg-4 text-center\"><img data-src=\"\\cdn.shopify.com/s/files/1/1632/5913/files/size_guide.png\"></div><div class=\"col-lg-8\"><table class=\"sizes-table\"><thead><tr><th>size</th><th>chest(in.)</th><th>waist(in.)</th><th>hips(in.)</th></tr></thead><tbody><tr><th>XS</th><td>34-36</td><td>27-29</td><td>34.5-36.5</td></tr><tr><th>S</th><td>36-38</td><td>29-31</td><td>36.5-38.5</td></tr><tr><th>M</th><td>38-40</td><td>31-33</td><td>38.5-40.5</td></tr><tr><th>L</th><td>40-42</td><td>33-36</td><td>40.5-43.5</td></tr><tr><th>XL</th><td>42-45</td><td>36-40</td><td>43.5-47.5</td></tr><tr><th>XXL</th><td>45-48</td><td>40-44</td><td>47.5-51.5</td></tr></tbody></table></div></div>"
        }
      ]
    },
    {
      "type": "html",
      "name": "t:sections.product-page-tab.blocks.html.name",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "t:sections.product-page-tab.blocks.general.settings.title.label",
          "default": "Shipping & Delivery"
        },
        {
          "type": "html",
          "id": "code",
          "label": "t:sections.product-page-tab.blocks.general.settings.code.label"
        }
      ]
    }
  ]
}
{% endschema %}

{% stylesheet %}
.product-tabs.accordion {
  border-top: 2px solid #dae2e6;
}
.product-tabs.accordion .accordion-item {
  border-bottom: 1px solid #dae2e6;
}
.product-tabs.accordion .accordion-toggle {
  display: flex;
  justify-content: space-between;
  align-items: center;
  width: 100%;
  background: none;
  border: none;
  border-radius: 0;
  text-align: left;
  padding: 16px 0;
  cursor: pointer;
  font-size: 14px;
}
.product-tabs.accordion .tab-content {
  display: none;
  padding: 0 0 24px;
  font-size: 14px;
  line-height: 27px;
}
.product-tabs.accordion .tab-content.show {
  display: block;
}
/* +/- icon */
.product-tabs.accordion .accordion-icon {
  flex-shrink: 0;
  position: relative;
  width: 16px;
  height: 16px;
  margin-left: 12px;
}
.product-tabs.accordion .accordion-icon::before,
.product-tabs.accordion .accordion-icon::after {
  content: '';
  position: absolute;
  background: currentColor;
  transition: transform 0.2s ease, opacity 0.2s ease;
}
.product-tabs.accordion .accordion-icon::before {
  width: 16px;
  height: 2px;
  top: 7px;
  left: 0;
}
.product-tabs.accordion .accordion-icon::after {
  width: 2px;
  height: 16px;
  top: 0;
  left: 7px;
}
.product-tabs.accordion .accordion-toggle.active .accordion-icon::after {
  transform: rotate(90deg);
  opacity: 0;
}
{% endstylesheet %}

{% javascript %}
document.addEventListener('DOMContentLoaded', function () {
  var accordion = document.querySelector('.product-tabs.accordion');
  if (!accordion) return;

  accordion.querySelectorAll('.accordion-toggle').forEach(function (toggle) {
    toggle.addEventListener('click', function () {
      var isActive = this.classList.contains('active');

      // Close all panels
      accordion.querySelectorAll('.accordion-toggle').forEach(function (t) {
        t.classList.remove('active');
        t.setAttribute('aria-expanded', 'false');
        var panel = document.getElementById(t.getAttribute('aria-controls'));
        if (panel) panel.classList.remove('show', 'active');
      });

      // Open clicked panel if it wasn't already open
      if (!isActive) {
        this.classList.add('active');
        this.setAttribute('aria-expanded', 'true');
        var panel = document.getElementById(this.getAttribute('aria-controls'));
        if (panel) panel.classList.add('show', 'active');
      }
    });
  });
});
{% endjavascript %}
